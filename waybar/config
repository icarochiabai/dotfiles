{
"layer": "top",
"position": "top",
"modules-left": ["idle_inhibitor", "cpu", "temperature", "memory", "disk", "pulseaudio", "backlight", "custom/cap-left"],
"modules-center": ["wlr/workspaces"],
"modules-right": ["custom/cap-right", "custom/screenshot", "custom/weather", "custom/vpn", "network", "clock", "battery"],
"wlr/window": {
},
"custom/weather": {
  "tooltip": false,
  "min-length": 5,
  "exec": "curl 'https://wttr.in/?m&format='%t''",
  "interval": 3600,
},
"battery": {
  "min-length": 5,
  "states": {
  "full": 90,
  "warning": 30,
  "critical": 15,
  },
  "tooltip": false,
  "full-at": 95,
  "format-plugged": "{icon} {capacity}%",
  "format-charging": "{icon} {capacity}%",
  "format": "{icon} {capacity}%",
  "format-alt": "{icon} {time}",
  "format-icons": ["пХє", "пХЇ", "пХї", "пХЉ", "пХљ", "пХЊ", "пХњ", "пЦА", "пЦБ", "пХЄ"],
},
"clock": {
  "format": "{:%b %d пАЧ %H:%M:%S}",
  "tooltip": false,
  "interval": 1,
  "min-length": 18,
},
"custom/offswitch": {
  "tooltip": false,
  "format": "пАС",
  "interval": "once",
  "on-click": "systemctl poweroff",
},
"network": {
  "interval": 2,
  "format-wifi": "{essid} ({signalStrength}%) пЗЂ",
  "format-ethernet": "{ipaddr}/{cidr} пЮЦ",
  "tooltip-format": "{ifname} via {gwaddr} пЮЦ",
  "format-linked": "{ifname} (No IP) пЮЦ",
  "format-disconnected": "Disconnected вЪ†",
  "format-alt": "{ifname}: {ipaddr}/{cidr}",
  "format-disabled": "",
  "tooltip": false,
  "min-length": 6,
},
"custom/vpn": {
    "format": "пА£ VPN",
    "exec": "echo '{\"class\": \"connected\"}'",
    "exec-if": "test -d /proc/sys/net/ipv4/conf/tun0",
    "return-type": "json",
    "interval": 2
},
"pulseaudio": {
  "reverse-scrolling": 1,
  "tooltip": false,
  "min-length": 5,
  "format": "{icon} {volume}%",
  "format-bluetooth": "{icon} {volume}%",
  "format-muted": "MUTE",
  "format-icons": {
  "headphone": "пА•",
  "headset": "пКФ",
  "default": ["пА¶", "пАІ", "пА®"],
  },
},
"idle_inhibitor": {
  "tooltip": false,
	"format": "{icon}",
	"format-icons": {
	"activated": "пИЕ",
	"deactivated": "пИД",
  },
},
"cpu": {
  "interval": 4,
  "min-length": 6,
  "format": "пАУ {usage}%",
  "tooltip": false,
  "states": {
  "critical": 90,
  },
},
"temperature": {
  "tooltip": false,
  "min-length": 5,
  "critical-threshold": 90,
  "format": "{icon} {temperatureC}¬∞C",
  "format-critical": "{icon} {temperatureC}¬∞C",
  "format-icons": {
  "default": ["пЛЛ", "пЛК", "пЛЙ", "пЛИ", "пЛЗ"],
  },
},
"memory": {
  "tooltip": false,
  "format": "пЛЫ {percentage}%",
  "states": {
    "critical":90,
  },
  "min-length": 5,
},
"disk": {
  "tooltip": false,
  "path": "/",
  "interval": 60,
  "min-length": 5,
  "format": "пБї {percentage_used}%",
  "states": {
  "critical": 90,
  },
},
"wlr/workspaces": {
  "format": "{name}",
  "on-click": "activate",
},
"backlight": {
        "format": "{percent}% {icon}",
        "format-icons": ["оОН", "оПУ", "оПС", "оПП", "оПО", "оПН", "оПК", "оПИ", "оОЫ"],
	"on-scroll-up":"light -T 0.99",
	"on-scroll-down":"light -T 1.01",
},
"custom/screenshot":{
	"format": "пШГ",
	"on-click": "grim ~/Pictures/Screenshots/Screenshot-$(date '+%H:%M:%S_%d-%m-%Y').png",
},
"custom/cap-left": {
  "tooltip": false,
	"format": "оВ∞",
},
"custom/cap-right": {
  "tooltip": false,
	"format": "оВ≤",
},

}
